{
  "name": "flickr-mcp dev",
  "dockerComposeFile": [
    "../docker-compose.yml",
    "../docker-compose.dev.yml"
  ],
  "service": "mcp",
  "workspaceFolder": "/app",
  "remoteUser": "root",
  "forwardPorts": [8000],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylint"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },
  "postStartCommand": "echo 'flickr-mcp dev container ready. Scripts are live-mounted at /app/scripts'"
}
